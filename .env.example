KORTIX_HOME=/workspace
KORTIX_DB_PATH=/workspace/.kortix/kortix.db
KORTIX_AGENTS_DIR=/workspace/.opencode/agents
KORTIX_SOURCE_AGENTS_DIR=/workspace/agents
KORTIX_SKILLS_DIR=/workspace/.opencode/skills
KORTIX_SOURCE_SKILLS_DIR=/workspace/skills
KORTIX_SHARED_CONTEXT_PATH=/workspace/.kortix/memory/shared-context.json
NODE_ENV=production

OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_OUTPUT_TOKENS=4096
LEAD_SCORING_MODE=auto

STRIPE_SECRET_KEY=replace-me
STRIPE_WEBHOOK_SECRET=replace-me
STRIPE_PRICE_ID=replace-me

NEXTAUTH_SECRET=replace-me
NEXTAUTH_URL=https://kortix.example.com
DASHBOARD_PORT=43123
STRIPE_WEBHOOK_PORT=43124

AUTOWORK_INTERVAL_MINUTES=15
AUTOWORK_BATCH_SIZE=50
AUTOWORK_MAX_CONCURRENT=5
AUTOWORK_LOG_PATH=/workspace/logs/autowork.log
STRUCTURED_LOG_DIR=/workspace/logs

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/replace-me
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=replace-me
EMAIL_SMTP_PASS=replace-me
