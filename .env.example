# ════════════════════════════════════════════════════════════════════
#  MLeads — Configuración completa
# ════════════════════════════════════════════════════════════════════
# Copia este archivo a `.env` y completa los valores para tu entorno:
#   cp .env.example .env
#
# Lo MÍNIMO requerido para arrancar es:
#   - TELEGRAM_BOT_TOKEN
#   - TELEGRAM_CHAT_ID
#   - JWT_SECRET_KEY  (si usas el dashboard web)
#
# El resto son opcionales: APIs externas para enriquecer leads,
# ajustes de rendimiento, flags de agentes, etc.
# ════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────
#  1. Telegram (REQUERIDO)
# ─────────────────────────────────────────────────────────────────────
# Token del bot — pídelo a @BotFather → /newbot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# Chat ID donde se envían los leads (negativo para grupos)
# Para obtenerlo: agrega el bot al grupo, envía un mensaje y visita
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=-1001234567890
# Rate-limiting del bot
TELEGRAM_MAX_MSG_MIN=20
TELEGRAM_MAX_BURST=10

# ── Interactive Bot (Phase 3) ───────────────────────────────────────
# El bot long-polls para atender conversaciones privadas y onboarding.
# Cuando un usuario se une al canal configurado abajo le activa 7 días
# de trial automáticamente.
BOT_WORKER_ENABLED=true
# ID del canal público/privado que los usuarios se subscriben para
# activar el trial automático (ej: @mi_canal o -1001234567890).
# IMPORTANTE: el bot debe ser admin del canal para recibir updates.
TELEGRAM_CHANNEL_ID=
BOT_TRIAL_DAYS=7
BOT_DEFAULT_RADIUS_MILES=35
BOT_PRICE_USD=99
BOT_POLL_TIMEOUT=25


# ─────────────────────────────────────────────────────────────────────
#  2. Base de datos
# ─────────────────────────────────────────────────────────────────────
DB_PATH=data/leads.db


# ─────────────────────────────────────────────────────────────────────
#  3. Servidor Web / Dashboard
# ─────────────────────────────────────────────────────────────────────
PORT=5001
FLASK_DEBUG=false
FLASK_ENV=production


# ─────────────────────────────────────────────────────────────────────
#  4. Autenticación JWT  (REQUERIDO si usas el dashboard)
# ─────────────────────────────────────────────────────────────────────
# IMPORTANTE: Cambia esta clave en producción. Usa un string aleatorio largo:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-in-production-use-strong-random-key
JWT_ACCESS_EXPIRY=3600        # Token de acceso: 1 hora
JWT_REFRESH_EXPIRY=604800     # Token de refresh: 7 días


# ─────────────────────────────────────────────────────────────────────
#  5. Contactos (CSVs locales para fuzzy matching)
# ─────────────────────────────────────────────────────────────────────
CONTACTS_DIR=contacts
FUZZY_THRESHOLD=0.72          # 0.0–1.0  (más alto = más estricto)


# ─────────────────────────────────────────────────────────────────────
#  6. Logging
# ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/mleads.log


# ════════════════════════════════════════════════════════════════════
#  7. Activación de agentes (true/false)
# ════════════════════════════════════════════════════════════════════
AGENT_PERMITS=true
AGENT_SOLAR=true
AGENT_RODENTS=true
AGENT_FLOOD=true
AGENT_CONSTRUCTION=true
AGENT_DECONSTRUCTION=true
AGENT_REALESTATE=true
AGENT_ENERGY=true
AGENT_PLACES=false            # Requiere GOOGLE_PLACES_API_KEY
AGENT_YELP=false              # Requiere YELP_API_KEY


# ════════════════════════════════════════════════════════════════════
#  8. Intervalos de fetch (en minutos)
# ════════════════════════════════════════════════════════════════════
INTERVAL_PERMITS=60
INTERVAL_SOLAR=60
INTERVAL_RODENTS=120
INTERVAL_FLOOD=30
INTERVAL_CONSTRUCTION=60
INTERVAL_DECONSTRUCTION=120
INTERVAL_REALESTATE=120
INTERVAL_ENERGY=360
INTERVAL_PLACES=1440
INTERVAL_YELP=1440


# ════════════════════════════════════════════════════════════════════
#  9. Tuning de rendimiento
# ════════════════════════════════════════════════════════════════════
SOURCE_TIMEOUT=45             # Timeout HTTP por fuente (segundos)
PARALLEL_CITIES=6             # Threads paralelos para permits
PARALLEL_SOLAR=6
PARALLEL_311=5                # Para rodents (311 reports)
PARALLEL_INSPECT=6            # Para construction inspections
PARALLEL_REALESTATE=4
PARALLEL_ENERGY=4
PARALLEL_DECON=6


# ════════════════════════════════════════════════════════════════════
# 10. Filtros de leads
# ════════════════════════════════════════════════════════════════════
MIN_PERMIT_VALUE=50000        # USD mínimo para permit/solar
MIN_DECON_VALUE=50000         # USD mínimo para deconstruction
MIN_SALE_PRICE=400000         # USD mínimo para venta inmobiliaria

PERMIT_MONTHS=3               # Histórico permits (meses)
RODENT_MONTHS=2               # Histórico reportes 311
DECON_MONTHS=3                # Histórico deconstruction
CONSTRUCTION_MONTHS=1         # Histórico construction
SALE_MONTHS=2                 # Histórico ventas
ENERGY_MONTHS=6               # Histórico energy benchmarking


# ════════════════════════════════════════════════════════════════════
# 11. Deduplicación cross-agent
# ════════════════════════════════════════════════════════════════════
DEDUP_WINDOW_DAYS=30          # Ventana para evitar reenvío del mismo lead


# ════════════════════════════════════════════════════════════════════
# 12. Hot Zone Detection (clustering geográfico)
# ════════════════════════════════════════════════════════════════════
HOT_ZONE_THRESHOLD=3          # Mínimo de leads para activar hot zone
HOT_ZONE_RADIUS_M=500         # Radio del cluster (metros)
HOT_ZONE_WINDOW_HRS=168       # Ventana temporal (horas) — default 7 días


# ════════════════════════════════════════════════════════════════════
# 13. Calendario de Inspecciones
# ════════════════════════════════════════════════════════════════════
INSPECTION_FETCH_HOUR=9       # Hora diaria de fetch (formato 24h, UTC)
INSPECTION_CLEANUP_DAYS=60    # Días tras los cuales se borran los registros
ENABLE_CONTRA_COSTA_FETCHER=true
ENABLE_BERKELEY_FETCHER=true
ENABLE_SAN_JOSE_FETCHER=true
ENABLE_LEAD_SCORING=true
ENABLE_INSPECTION_SCHEDULER=true


# ════════════════════════════════════════════════════════════════════
# 14. APIs públicas / gratuitas
# ════════════════════════════════════════════════════════════════════
# Socrata — usa todos los portales data.* (SF, Oakland, etc.)
# Sin token funciona pero con throttling. Crear gratis en cualquier
# data.*.gov → My Profile → App Tokens
SOCRATA_APP_TOKEN=

# NREL — solar potential. Free: https://developer.nrel.gov/signup/
NREL_API_KEY=

# US Census — demografía. Free: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=


# ════════════════════════════════════════════════════════════════════
# 15. APIs de pago / freemium (opcionales — enriquecen los leads)
# ════════════════════════════════════════════════════════════════════

# ── Google Cloud ──────────────────────────────────────────────────────
# Places API — negocios cercanos ($200 crédito gratis/mes)
GOOGLE_PLACES_API_KEY=
# Geocoding API — convertir direcciones en coordenadas (~$30/mes)
GOOGLE_GEOCODE_API_KEY=
# Solar API — datos solares por edificio (~$0.40/request)
GOOGLE_SOLAR_API_KEY=

# ── Yelp Fusion ───────────────────────────────────────────────────────
# Free: 5000 calls/día — https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=

# ── ATTOM Property Data ───────────────────────────────────────────────
# https://api.gateway.attomdata.com  (~$200/mes)
ATTOM_API_KEY=

# ── Aurora Solar ──────────────────────────────────────────────────────
# Aurora design platform — partner API
AURORA_API_KEY=

# ── EnergySage ────────────────────────────────────────────────────────
# Marketplace de instaladores solares
ENERGYSAGE_API_KEY=

# ── BuildZoom ─────────────────────────────────────────────────────────
# Tracking de construction permits ($100–300/mes)
BUILDZOOM_API_KEY=

# ── Thumbtack ─────────────────────────────────────────────────────────
# Pest control / contractor leads — partner program
# https://www.thumbtack.com/developers
THUMBTACK_API_KEY=


# ════════════════════════════════════════════════════════════════════
# 16. Contact enrichment
# ════════════════════════════════════════════════════════════════════
# Hunter.io — email finder por dominio (100 gratis, $49/mes)
HUNTER_API_KEY=
# Apollo.io — contact enrichment (free tier disponible)
APOLLO_API_KEY=


# ════════════════════════════════════════════════════════════════════
# 17. Notificaciones multi-canal
# ════════════════════════════════════════════════════════════════════

# ── SendGrid (Email outreach) ─────────────────────────────────────────
# Free: 100 emails/día.  $15/mes para volumen mayor.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=leads@example.com
SENDGRID_TO_EMAIL=tu@email.com

# ── Twilio (WhatsApp para leads HOT) ─────────────────────────────────
# https://www.twilio.com/whatsapp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+1XXXXXXXXXX

# ── Slack (webhook para canales internos) ────────────────────────────
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=


# ════════════════════════════════════════════════════════════════════
# 18. Stripe — Billing para suscripciones del bot ($99/mo)
# ════════════════════════════════════════════════════════════════════
# Si dejas STRIPE_API_KEY vacío, el módulo billing queda en modo no-op
# y el bot seguirá funcionando sin cobrar — útil para desarrollo.
#
# Para producción:
#   1. Crea un producto "MLeads Pro" en https://dashboard.stripe.com/products
#   2. Añade un precio recurrente de $99/mes → copia el price_id (price_xxx)
#   3. Configura el webhook en Stripe apuntando a
#        https://tu-dominio.com/api/stripe/webhook
#      con los eventos: checkout.session.completed,
#        invoice.paid, customer.subscription.deleted
STRIPE_API_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://t.me/
STRIPE_CANCEL_URL=https://t.me/
