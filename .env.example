# MLeads Configuration File
# Copy this file to .env and update values for your environment

# ─────────────────────────────────────────────────
# Database Configuration
# ─────────────────────────────────────────────────
DB_PATH=data/leads.db

# ─────────────────────────────────────────────────
# Web Server Configuration
# ─────────────────────────────────────────────────
PORT=5001
FLASK_DEBUG=false
FLASK_ENV=production

# ─────────────────────────────────────────────────
# Authentication & Security
# ─────────────────────────────────────────────────
# IMPORTANT: Change this in production! Use a strong random string.
JWT_SECRET_KEY=change-me-in-production-use-strong-random-key
JWT_ACCESS_EXPIRY=3600
JWT_REFRESH_EXPIRY=604800

# ─────────────────────────────────────────────────
# Inspection Calendar Configuration
# ─────────────────────────────────────────────────
INSPECTION_FETCH_HOUR=9
INSPECTION_CLEANUP_DAYS=60

# ─────────────────────────────────────────────────
# Feature Flags
# ─────────────────────────────────────────────────
ENABLE_CONTRA_COSTA_FETCHER=true
ENABLE_BERKELEY_FETCHER=true
ENABLE_SAN_JOSE_FETCHER=true
ENABLE_LEAD_SCORING=true
ENABLE_INSPECTION_SCHEDULER=true

# ─────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/mleads.log

# ─────────────────────────────────────────────────
# Agent Configuration (if using construction agents)
# ─────────────────────────────────────────────────
AGENT_SOLAR=false
AGENT_POOL=false
AGENT_REMODEL=true
